test.describe.skip('Project Creation Flow', () => {
  test('Create new research project', async ({ page }) => {
    await page.goto(ROUTES.PROJECTS);

    // Click create project
    await page.click('button:has-text("Create Project")');

    // Fill project form
    await page.fill('input[name="title"]', TEST_PROJECT.title);
    await page.selectOption('select[name="category"]', TEST_PROJECT.category);

    // Add milestones
    for (const milestone of TEST_PROJECT.milestones) {
      await page.click('button:has-text("Add Milestone")');
      await page.fill('input[name="milestoneTitle"]', milestone.title);
      await page.fill('input[name="milestoneGoal"]', milestone.goal);
      await page.fill('input[name="milestoneDuration"]', milestone.duration.toString());
    }

    // Submit form
    await page.click('button:has-text("Deploy Project")');

    // TODO: Handle MetaMask transaction approval
    // await metamask.confirmTransaction();

    // Wait for transaction confirmation
    await page.waitForSelector('text=/Project created/i', { timeout: 60000 });

    // Verify project appears in list
    await expect(page.locator('text=' + TEST_PROJECT.title)).toBeVisible();
  });
});

